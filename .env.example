# ──────────────────────────────────────────────────────────────────────────────
# Canvas Image Builder — Environment Variables
# Copy this file to .env.local (gitignored) for local overrides.
# Set these as Vercel / CI environment variables for production.
# ──────────────────────────────────────────────────────────────────────────────

# ── Brand ─────────────────────────────────────────────────────────────────────
VITE_BRAND_NAME=Canvas Studio

# ── Auth mode ─────────────────────────────────────────────────────────────────
# false → local admin login is active (default for production)
# true  → auth is bypassed entirely; use when the host app handles auth
#         externally (E2E testing, iframe embedding with ?token= JWT)
VITE_DISABLE_AUTH=false

# ── Admin credentials (only used when VITE_DISABLE_AUTH=false) ───────────────
# Override in Vercel environment variables — never commit real passwords here.
VITE_ADMIN_EMAIL=admin@canvas.studio
VITE_ADMIN_PASSWORD=Canvas@2025!

# ── External JWT auth (optional) ─────────────────────────────────────────────
# When integrating your own auth system:
#   1. Keep VITE_DISABLE_AUTH=false
#   2. Generate a short-lived JWT on your backend containing:
#        { sub, email, name, brandName? }
#   3. Redirect the user to: https://your-editor.app?token=<jwt>
#   The editor validates the token client-side and stores it in sessionStorage.
